{
  "version": 1,
  "description": "ocb E2E test specification. Standardized sessions and assertions for all contributors.",
  "projects": [
    {
      "id": "project-a",
      "description": "Main test project with 3 sessions covering naming, viewing, switching, deleting",
      "files": ["README.md"],
      "sessions": [
        {
          "id": "pa-s1",
          "alias": "auth-feature",
          "message": "hi"
        },
        {
          "id": "pa-s2",
          "alias": "fix-css",
          "message": "hi"
        },
        {
          "id": "pa-s3",
          "alias": null,
          "message": "hi"
        }
      ]
    },
    {
      "id": "project-b",
      "description": "Isolation verification project with 1 session for cross-project isolation tests",
      "files": ["README.md"],
      "sessions": [
        {
          "id": "pb-s1",
          "alias": "api-work",
          "message": "hi"
        }
      ]
    }
  ],
  "test_sequence": [
    {
      "phase": 1,
      "description": "Phase 1: View + Naming",
      "steps": [
        {
          "id": "T01",
          "name": "origin available lists all unmanaged",
          "cwd": "project-a",
          "command": "ocb origin available",
          "assert": ["${PA_S1_SID:0:15}", "${PA_S2_SID:0:15}", "${PA_S3_SID:0:15}"],
          "assert_not": ["${PB_S1_SID:0:15}"]
        },
        {
          "id": "T02",
          "name": "attach by explicit session id",
          "cwd": "project-a",
          "command": "ocb attach auth-feature -s ${PA_S1_SID}",
          "assert": ["Created: auth-feature"]
        },
        {
          "id": "T03",
          "name": "attach second session by sid",
          "cwd": "project-a",
          "command": "ocb attach fix-css -s ${PA_S2_SID}",
          "assert": ["Created: fix-css"]
        },
        {
          "id": "T04",
          "name": "list shows 2 managed sessions",
          "cwd": "project-a",
          "command": "ocb list",
          "assert": ["auth-feature", "fix-css"],
          "assert_not": ["${PA_S3_SID:0:15}"]
        },
        {
          "id": "T05",
          "name": "origin available only shows pa-s3",
          "cwd": "project-a",
          "command": "ocb origin available",
          "assert": ["${PA_S3_SID:0:15}"],
          "assert_not": ["auth-feature", "fix-css"]
        },
        {
          "id": "T06",
          "name": "show displays message list",
          "cwd": "project-a",
          "command": "ocb show auth-feature",
          "assert": ["User"],
          "min_lines": 2
        },
        {
          "id": "T07",
          "name": "show -m shows specific message",
          "cwd": "project-a",
          "command": "ocb show auth-feature -m 1",
          "min_lines": 1
        },
        {
          "id": "T08",
          "name": "checkout switches active session",
          "cwd": "project-a",
          "command": "ocb checkout auth-feature",
          "assert": ["Switched to auth-feature"]
        },
        {
          "id": "T09",
          "name": "list shows * on active",
          "cwd": "project-a",
          "command": "ocb list",
          "assert": ["* auth-feature"]
        },
        {
          "id": "T10",
          "name": "rename changes alias",
          "cwd": "project-a",
          "command": "ocb rename auth-feature login-module",
          "assert": ["Renamed:", "login-module"]
        },
        {
          "id": "T11",
          "name": "list reflects new name",
          "cwd": "project-a",
          "command": "ocb list",
          "assert": ["login-module", "fix-css"],
          "assert_not": ["auth-feature"]
        },
        {
          "id": "T12",
          "name": "show works with new name",
          "cwd": "project-a",
          "command": "ocb show login-module -m 1",
          "min_lines": 1
        },
        {
          "id": "T13",
          "name": "show works with raw session id",
          "cwd": "project-a",
          "command": "ocb show ${PA_S1_SID} -m 1",
          "min_lines": 1
        },
        {
          "id": "T14",
          "name": "unmanage removes from list",
          "cwd": "project-a",
          "command": "ocb unmanage fix-css",
          "assert": ["Removed fix-css"]
        },
        {
          "id": "T15",
          "name": "list no longer shows unmanaged",
          "cwd": "project-a",
          "command": "ocb list",
          "assert": ["login-module"],
          "assert_not": ["fix-css"]
        },
        {
          "id": "T16",
          "name": "origin available shows unmanaged again",
          "cwd": "project-a",
          "command": "ocb origin available",
          "assert": ["${PA_S2_SID:0:15}"]
        },
        {
          "id": "T17",
          "name": "cross-project isolation",
          "cwd": "project-b",
          "command": "ocb list",
          "assert": ["No managed sessions"]
        },
        {
          "id": "T17b",
          "name": "attach without -s picks most recent in project-b",
          "cwd": "project-b",
          "command": "ocb attach api-work",
          "assert": ["Created: api-work", "${PB_S1_SID:0:15}"]
        },
        {
          "id": "T18",
          "name": "project-b list shows own only",
          "cwd": "project-b",
          "command": "ocb list",
          "assert": ["api-work"],
          "assert_not": ["login-module", "fix-css"]
        },
        {
          "id": "T19",
          "name": "project-b show works",
          "cwd": "project-b",
          "command": "ocb show api-work",
          "assert": ["User"],
          "min_lines": 2
        },
        {
          "id": "T20",
          "name": "delete -f removes session",
          "cwd": "project-a",
          "command": "ocb delete ${PA_S3_SID} -f",
          "assert": ["Deleted"]
        },
        {
          "id": "T21",
          "name": "deleted not in origin available",
          "cwd": "project-a",
          "command": "ocb origin available",
          "assert_not": ["${PA_S3_SID:0:15}"]
        },
        {
          "id": "T22",
          "name": "show nonexistent returns error",
          "cwd": "project-a",
          "command": "ocb show nonexistent-xyz",
          "exit_code": 1,
          "assert": ["Error"]
        }
      ]
    },
    {
      "phase": 2,
      "description": "Phase 2: Fork + Graph",
      "steps": [
        {
          "id": "T23",
          "name": "checkout -b forks from named session",
          "cwd": "project-a",
          "command": "ocb checkout -b fork-test login-module --model minimax-cn-coding-plan/MiniMax-M2.7",
          "assert": ["Forking from login-module"]
        },
        {
          "id": "T24",
          "name": "fork-test appears in list",
          "cwd": "project-a",
          "command": "ocb list",
          "assert": ["fork-test"]
        },
        {
          "id": "T25",
          "name": "graph shows fork tree",
          "cwd": "project-a",
          "command": "ocb graph",
          "assert": ["fork-test"],
          "min_lines": 2
        }
      ]
    },
    {
      "phase": 3,
      "description": "Phase 3: Compact + Reflog + Rollback",
      "steps": [
        {
          "id": "T26",
          "name": "reflog shows no entries for new name",
          "cwd": "project-a",
          "command": "ocb reflog fork-test",
          "assert": ["No reflog entries"]
        },
        {
          "id": "T27",
          "name": "compact with --manual compresses messages",
          "cwd": "project-a",
          "command": "ocb compact login-module -m 1-1 --manual 'Test summary' --model minimax-cn-coding-plan/MiniMax-M2.7",
          "assert": ["compressed"]
        },
        {
          "id": "T28",
          "name": "reflog shows compact entry for new name",
          "cwd": "project-a",
          "command": "ocb reflog login-module-c1",
          "assert": ["compact"]
        },
        {
          "id": "T29",
          "name": "compact creates new named session with -c suffix",
          "cwd": "project-a",
          "command": "ocb list",
          "assert": ["login-module-c1"]
        },
        {
          "id": "T30",
          "name": "rollback reverts name to previous version",
          "cwd": "project-a",
          "command": "ocb rollback login-module-c1 -f",
          "assert": ["rolled back"]
        },
        {
          "id": "T31",
          "name": "reflog shows rollback entry",
          "cwd": "project-a",
          "command": "ocb reflog login-module-c1",
          "assert": ["rollback"]
        },
        {
          "id": "T32",
          "name": "model command shows no config",
          "cwd": "project-a",
          "command": "ocb model",
          "assert": ["No default model"]
        },
        {
          "id": "T33",
          "name": "model --list lists available models",
          "cwd": "project-a",
          "command": "ocb model --list",
          "min_lines": 2
        }
      ]
    }
  ]
}
